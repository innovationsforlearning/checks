{
  "name": "system-check",
  "version": "0.1.0",
  "private": false,
  "description": "Browser-based device readiness check — webcam, mic, speakers, keyboard, touch, network latency, bandwidth, and WebRTC reachability.",
  "type": "module",
  "license": "MIT",
  "author": "Innovations for Learning",
  "homepage": "https://github.com/innovationsforlearning/checks#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/innovationsforlearning/checks.git"
  },
  "bugs": {
    "url": "https://github.com/innovationsforlearning/checks/issues"
  },
  "keywords": [
    "system-check",
    "device-check",
    "webrtc",
    "webcam",
    "microphone",
    "bandwidth",
    "diagnostics",
    "vite"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host",
    "start": "serve -s dist -l ${PORT:-3000}",
    "format": "prettier --write \"src/**/*.{js,css}\" \"*.{html,md,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,css}\" \"*.{html,md,json}\"",
    "heroku-postbuild": "npm run build"
  },
  "dependencies": {
    "serve": "^14.2.4"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "vite": "^5.4.10"
  }
}
